# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ─── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Distribution / packaging ────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ─── IDE / editor files ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ─── OS generated ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/*.log

# ─── Pipeline output data (regenerated by the pipeline) ─────────────────────
# Keep raw data; ignore everything downstream that is fully re-runnable.
data/processed/
data/matched/
data/validation/
data/analysis/
data/report/

# ─── Jupyter / IPython ──────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Misc ────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.log
